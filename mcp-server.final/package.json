{
  "name": "support-escalation-mcp",
  "version": "0.1.0",
  "description": "Support-ticket escalation MCP server for the Keycard workshop (reference implementation, secured through Chapter 6)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.9.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "build": "tsc",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "test": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.85",
    "@keycardai/mcp": "0.10.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@supabase/supabase-js": "2.108.2",
    "ai": "6.0.208",
    "express": "5.2.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "26.0.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
