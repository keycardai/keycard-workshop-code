# Server port. The MCP endpoint will be http://localhost:8000/mcp
PORT=8000

# The Keycard URL that issues and verifies tokens (the OAuth issuer). This is
# your issuer URL from Chapter 1; copy it from the console Settings page.
# No trailing slash.
KEYCARD_URL=

# This server's resource URI, exactly as registered in Keycard.
# Must include the /mcp path: Keycard matches the token audience by exact string.
# If you change PORT, this value AND the resource registered in Keycard must
# change with it, or every request gets a 401.
MCP_RESOURCE_URL=http://localhost:8000/mcp

# Your Keycard application's credentials (console → your application →
# Application Credentials). These authenticate the application itself to
# Keycard's token endpoint when it exchanges a caller's token for downstream
# credentials. They say which app is asking; the caller's token says who for.
# In a real app, you would use Workload Identity Federation instead of long-lived
# secrets in .env, but in local development, client id/secret must be used.
KEYCARD_CLIENT_ID=
KEYCARD_CLIENT_SECRET=

# Supabase project URL (provided by the instructor). This is also the vault
# resource identifier registered in Keycard, so it must match that
# registration exactly. Notice what is NOT here: the database credential.
# The secret API key lives in Keycard's vault and is exchanged per request;
# it never touches this file. In a real app, you would use Workload Identity
# Federation to get short-lived credentials for Supabase instead of a long-lived
# API key, but we must use vault here due to everyone having different Keycard issuers.
SUPABASE_URL=

# Linear team to create escalation issues in (provided by the instructor).
# Config, not a credential. The shared LINEAR_API_KEY that sat here for five
# chapters is gone: Linear access is now exchanged per request, per caller,
# per scope, like everything else.
LINEAR_TEAM_ID=030eb113-b144-44f8-864f-c0507c21e80d

# Linear API origin. Also the resource identifier registered in Keycard, so it
# must match that registration exactly. No credential here — every call exchanges
# the caller's token for a delegated, per-scope Linear token from Keycard.
LINEAR_API_URL=https://api.linear.app

# Anthropic API base URL. Also the vault resource identifier registered in your
# Keycard, so it must match that registration exactly. The API key is NOT here —
# it's exchanged from Keycard's vault per request, like the Supabase key.
ANTHROPIC_API_URL=https://api.anthropic.com
