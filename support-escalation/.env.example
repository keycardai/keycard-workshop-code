# Server port. The MCP endpoint will be http://localhost:8000/mcp
PORT=8000

# ⚠️ Shared workshop Linear API key (full access, provided by the instructor).
#
# A static key is often how agents get access today:
#
#   - TOO MUCH POWER: it can read, write, and delete anything in the workspace.
#     escalate_ticket only needs to create one issue, yet it runs with the keys
#     to the kingdom. A static key is provisioned once for everything that might
#     ever touch it; it can't be narrowed to what any given call actually needs.
#   - NO DELEGATION: the key IS its creator. Linear stamps every issue any of
#     us creates or trashes as that one person, and has no way to tell which of
#     the 30 of us actually did it. You can't audit or revoke one person
#     without cutting off everyone.
#   - ONE STATIC SECRET: the same long-lived string, in plain text, in .env, on
#     every laptop in this room. It never rotates; if it leaks, it leaks for
#     all of us at once.
#
# Keycard replaces this with tokens minted on demand: every call carries who
# you actually are (a real delegation chain in the audit log), scoped to exactly
# what that call needs, governed by policy. By the end, this key is gone.
# Format: a Linear personal API key, e.g. lin_api_xxxxxxxxxxxxxxxxxxxxxxxx
LINEAR_API_KEY=

# Linear team that escalation issues are created in (provided with the key).
# This is the team's UUID, not its name or key. Linear's issueCreate mutation
# takes a teamId, and createIssue() passes this value straight through. Config,
# not a credential: it says *where* the issue lands, not *who* may create it.
# The value below is the shared workshop team; leave it as-is unless told otherwise.
LINEAR_TEAM_ID=030eb113-b144-44f8-864f-c0507c21e80d

# Your Keycard application's credentials (console → your application →
# Application Credentials, shown once when you create them in Chapter 1).
# They authenticate the application itself to Keycard's token endpoint when
# it exchanges a caller's token for downstream credentials: they say which app
# is asking, while the caller's token says who it's for. Nothing reads these
# until Chapter 4, when the server starts exchanging tokens. In a real app you
# would use Workload Identity Federation instead of a long-lived secret in
# .env; for local development, client id/secret is the simplest way.
KEYCARD_CLIENT_ID=
KEYCARD_CLIENT_SECRET=
