# Server port. The MCP endpoint will be http://localhost:8000/mcp
PORT=8000

# Keycard zone that issues and verifies tokens (the OAuth issuer). This is
# YOUR zone from Chapter 1: https://<your-zone-id>.keycard.cloud
# (Zone ID is in the console under Zone Settings.) No trailing slash.
KEYCARD_URL=

# This server's resource URI, exactly as registered in your Keycard zone.
# Must include the /mcp path: Keycard matches the token audience by exact string.
# If you change PORT, this value AND the resource registered in your zone must
# change with it, or every request gets a 401.
MCP_RESOURCE_URL=http://localhost:8000/mcp

# Your Keycard application's credentials (console → your application →
# Application Credentials). These authenticate the application itself to your
# zone's token endpoint when it exchanges a caller's token for downstream
# credentials. They say which app is asking; the caller's token says who for.
# In a real app, you would use Workload Identity Federation instead of long-lived
# secrets in .env, but in local development, client id/secret must be used.
KEYCARD_CLIENT_ID=
KEYCARD_CLIENT_SECRET=

# Supabase project URL (provided by the instructor). This is also the vault
# resource identifier registered in your zone, so it must match that
# registration exactly. Notice what is NOT here: the database credential.
# The secret API key lives in Keycard's vault and is exchanged per request;
# it never touches this file. In a real app, you would use Workload Identity
# Federation to get short-lived credentials for Supabase instead of a long-lived
# API key, but we must use vault here due to everyone having different Keycard issuers.
SUPABASE_URL=

# ⚠️ Shared workshop Linear API key (full access, set by the instructor).
#
# This one variable is everything wrong with how agents get access today:
#
#   - TOO MUCH POWER: it can read, write, and delete anything in the workspace.
#     escalate_ticket only needs to create one issue, yet it runs with the keys
#     to the kingdom. A static key is provisioned once for everything that might
#     ever touch it; it can't be narrowed to what a given call actually needs.
#   - NO DELEGATION: the key IS its creator. Linear stamps every issue any of
#     us creates or trashes as that one person, and has no way to tell which of
#     the 30 of us actually did it. You can't audit or revoke one person
#     without cutting off everyone.
#   - ONE STATIC SECRET: the same long-lived string, in plain text, in .env, on
#     every laptop in this room. It never rotates; if it leaks, it leaks for
#     all of us at once.
#
# Keycard replaces this with tokens minted on demand: every call carries who
# you actually are (a real delegation chain in the audit log), scoped to exactly
# what that call needs, governed by policy. By the end, this key is gone.
LINEAR_API_KEY=

# Linear team to create escalation issues in (provided with the key).
LINEAR_TEAM_ID=030eb113-b144-44f8-864f-c0507c21e80d
